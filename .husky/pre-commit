#!/usr/bin/env sh
# Block commits of secret files
BLOCKED_PATTERNS="\.env$|\.env\.|\.pem$|\.key$|credentials\.json$"

staged_files=$(git diff --cached --name-only)

for file in $staged_files; do
  if echo "$file" | grep -qE "$BLOCKED_PATTERNS"; then
    echo "ERROR: Refusing to commit secret file: $file"
    echo "Remove it from staging: git reset HEAD $file"
    exit 1
  fi
done
