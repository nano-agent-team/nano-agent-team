FROM node:22-alpine
WORKDIR /app

# Copy package files and install production dependencies
COPY agent-runner/package.json agent-runner/package-lock.json* ./
RUN npm ci --omit=dev

# Copy compiled JavaScript
COPY agent-runner/dist/ ./dist/

# Create workspace mount points for volumes (vault, sessions, agent)
RUN mkdir -p /workspace/vault /workspace/sessions /workspace/agent

# Create non-root agent user (Alpine syntax) with home dir
RUN addgroup -S agent && adduser -S -G agent -h /home/agent -s /bin/sh agent

# Ensure workspace dirs are owned by agent
RUN chown -R agent:agent /workspace /app

# Set npm global prefix for non-root user (consistent with main Dockerfile)
ENV NPM_CONFIG_PREFIX=/home/agent/.npm-global
ENV PATH="/home/agent/.npm-global/bin:$PATH"
ENV HOME=/home/agent

USER agent

CMD ["node", "dist/index.js"]
