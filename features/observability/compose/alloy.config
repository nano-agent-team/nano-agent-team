// Grafana Alloy config — collect Docker logs from nano-agent-* containers

discovery.docker "containers" {
  host = "unix:///var/run/docker.sock"
}

discovery.relabel "nano_agents" {
  targets = discovery.docker.containers.targets

  // Keep only nano-agent-* containers
  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/nano-agent-.*"
    action        = "keep"
  }

  // Extract agent_id from container name (nano-agent-{id})
  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/nano-agent-(.*)"
    target_label  = "agent_id"
  }

  // Add container name label
  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/(.*)"
    target_label  = "container"
  }

  // Set job label
  rule {
    replacement  = "nano-agent-team"
    target_label = "job"
  }
}

loki.source.docker "agents" {
  host       = "unix:///var/run/docker.sock"
  targets    = discovery.relabel.nano_agents.output
  labels     = { "source" = "docker" }
  forward_to = [loki.process.pipeline.receiver]
}

loki.process "pipeline" {
  // Extract traceId from JSON log lines (Pino format)
  stage.json {
    expressions = {
      trace_id = "traceId",
      span_id  = "spanId",
      level    = "level",
      msg      = "msg",
    }
  }

  // Add traceId as structured metadata for trace-to-logs correlation
  stage.structured_metadata {
    values = {
      trace_id = "trace_id",
      span_id  = "span_id",
    }
  }

  // Add level label
  stage.labels {
    values = {
      level = "",
    }
  }

  forward_to = [loki.write.local.receiver]
}

loki.write "local" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }
}
