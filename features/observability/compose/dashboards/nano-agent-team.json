        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{span.ticket.id != \"\" || name =~ \"ticket.*\"}",
          "limit": 50
        }
      ]
    },
    {
      "title": "Agent Activity",
      "description": "All agent processing spans — what each agent did",
      "type": "table",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{resource.service.name =~ \"nano-agent-.*\"}",
          "limit": 30
        }
      ]
    },
    {
      "title": "Agent Logs",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 26 },
