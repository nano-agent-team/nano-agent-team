      "title": "Ticket Lifecycle",
      "description": "Ticket create → PM → Architect → Developer → Tester → Reviewer pipeline",
      "type": "table",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "tempo", "uid": "tempo" },
