# NATS server URL
NATS_URL=nats://localhost:4222

# Path to agents directory (defaults to ./agents)
AGENTS_DIR=./agents

# Data directory for persistent storage: vault (shared) and sessions (per-agent)
# Defaults to ~/nano-agent-team/data
DATA_DIR=~/nano-agent-team/data

# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Node environment: development, production
NODE_ENV=development

# ── Agent container configuration ───────────────────────────────────────────

# Docker image to use for agent containers
AGENT_IMAGE=nano-agent:latest

# Docker network mode: "host" (Linux) or "bridge" (Docker Desktop)
# host = container can reach NATS on localhost:4222 directly
# bridge = uses host.docker.internal instead of localhost
DOCKER_NETWORK=host

# Anthropic API key (required for agent containers in Phase 3+)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: redirect Claude Agent SDK through a proxy (e.g. Bedrock proxy or routing-proxy)
# ANTHROPIC_BASE_URL=http://localhost:8081

# Max number of automatic restart attempts before giving up
AGENT_RESTART_MAX=3

# Initial delay in ms before first restart (doubles each time — exponential backoff)
AGENT_RESTART_DELAY_MS=5000

# How often to poll Docker API for container health (ms)
HEALTH_CHECK_INTERVAL_MS=30000
